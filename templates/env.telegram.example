# Telegram Bot Configuration
# Copy this file to .env (or .env.local) and fill in your values.
# NEVER commit your real .env file to git.
#
# HOW TO GET THESE VALUES:
#   TELEGRAM_BOT_TOKEN  — Open Telegram, message @BotFather, type /newbot, follow prompts
#   TELEGRAM_CHAT_ID    — Message @userinfobot on Telegram to get your user ID
#                         For a group chat: add your bot to the group, send a message,
#                         then check https://api.telegram.org/bot<TOKEN>/getUpdates
#   CLAUDE_CODE_PATH    — Run: which claude  (on Mac/Linux) or where claude (on Windows)

TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID
CLAUDE_CODE_PATH=/path/to/claude

# Optional — set these if your Telegram bot script uses them
# TELEGRAM_PARSE_MODE=Markdown
# TELEGRAM_DISABLE_NOTIFICATION=false
